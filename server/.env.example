# Copy this file to .env and fill in your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# MODEL=sonnet
# PORT=3000
# PREVIEW_PORT=5174

# Vision snapshot budget per turn (idea 12): Élite vs MVP mode
# VISION_BUDGET=10
# VISION_BUDGET_MVP=3

# GitHub one-click push (idea 16): personal access token with the "repo" scope.
# Create one at https://github.com/settings/tokens (classic) or a fine-grained
# token with Contents: read/write. The owner login is read from the API.
# GITHUB_TOKEN=ghp_...

# Élève local (jalon D) — modèle OSS qui traite la routine à coût zéro.
# Défaut : Ollama local (gratuit, souverain). Lancer « ollama serve » à part.
# ELEVE_MODEL=qwen2.5-coder:7b
#
# Option « Élève turbo » — endpoint compatible OpenAI (DeepSeek, Together, etc.) :
# plus puissant mais PAYANT et non local (le code/prompts partent chez un tiers).
# Passe ELEVE_PROVIDER=openai puis renseigne l'URL de base, la clé et le modèle.
# ELEVE_PROVIDER=ollama            # ollama (défaut) | openai
# ELEVE_API_URL=https://api.deepseek.com/v1
# ELEVE_API_KEY=sk-...
# ELEVE_MODEL=deepseek-chat        # nom du modèle côté provider

# Figma design-to-code (idea 25): personal access token. Create one at
# https://www.figma.com/developers/api#access-tokens (scope: File content read).
# Paste a frame link in the chat ("Copy link to selection") and the agent reads it.
# FIGMA_TOKEN=figd_...
