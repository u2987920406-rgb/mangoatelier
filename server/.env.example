# Copy this file to .env and fill in your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# MODEL=sonnet
# PORT=3000
# PREVIEW_PORT=5174

# Vision snapshot budget per turn (idea 12): Élite vs MVP mode
# VISION_BUDGET=10
# VISION_BUDGET_MVP=3

# GitHub one-click push (idea 16): personal access token with the "repo" scope.
# Create one at https://github.com/settings/tokens (classic) or a fine-grained
# token with Contents: read/write. The owner login is read from the API.
# GITHUB_TOKEN=ghp_...
