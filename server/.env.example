# Copy this file to .env and fill in your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# MODEL=sonnet
# PORT=3000
# PREVIEW_PORT=5174

# Vision snapshot budget per turn (idea 12): Élite vs MVP mode
# VISION_BUDGET=10
# VISION_BUDGET_MVP=3

# GitHub one-click push (idea 16): personal access token with the "repo" scope.
# Create one at https://github.com/settings/tokens (classic) or a fine-grained
# token with Contents: read/write. The owner login is read from the API.
# GITHUB_TOKEN=ghp_...

# Élève local (jalon D) — modèle OSS qui traite la routine à coût zéro.
# Défaut : Ollama local (gratuit, souverain). Lancer « ollama serve » à part.
# ELEVE_MODEL=gemma4:12b
#
# Option « Élève turbo » — endpoint compatible OpenAI (DeepSeek, Together, etc.) :
# plus puissant mais PAYANT et non local (le code/prompts partent chez un tiers).
# Passe ELEVE_PROVIDER=openai puis renseigne l'URL de base, la clé et le modèle.
# ELEVE_PROVIDER=ollama            # ollama (défaut) | openai
# ELEVE_API_URL=https://api.deepseek.com/v1
# ELEVE_API_KEY=sk-...
# ELEVE_MODEL=deepseek-chat        # nom du modèle côté provider

# ── Chantier #57 — Indépendance fournisseur LLM ──────────────────────────────
#
# Provider global pour toutes les features IA (défaut : claude = abonnement $0).
# Valeurs acceptées : claude | ollama | openai | deepseek | mistral | groq
# LLM_PROVIDER=claude
#
# Surcharge par feature (prioritaire sur LLM_PROVIDER) :
# FEEDBACK_PROVIDER=claude
# QA_PROVIDER=claude
# IDEATION_PROVIDER=claude
# DOC_PROVIDER=claude
# CRON_PROVIDER=claude
#
# Modèle utilisé par le reviewer Hermes (défaut : haiku via l'abonnement) :
# REVIEW_MODEL=haiku
#
# Clés pour les providers OpenAI-compatibles tiers :
# DEEPSEEK_API_KEY=sk-...          # deepseek-chat par défaut
# MISTRAL_API_KEY=...              # mistral-large-latest par défaut
# GROQ_API_KEY=gsk_...             # llama-3.3-70b-versatile par défaut
#
# Provider openai générique (URL + clé libres) :
# LLM_OPENAI_URL=https://api.deepseek.com/v1
# LLM_OPENAI_KEY=sk-...

# ── Idée #73 — L'armée automatique ───────────────────────────────────────────
#
# Patrouilleurs spécialisés (accessibilité, sécurité, SEO, perf, bundle) réveillés
# AUTOMATIQUEMENT après chaque tour selon les fichiers modifiés + le type de projet.
# Tournent en arrière-plan ($0 via l'abonnement) ; rapport compact injecté au chat.
# Activé par défaut. Kill-switch :
# PATROL_ENABLED=0
#
# Provider des patrouilleurs (défaut : claude = abonnement $0) :
# PATROL_PROVIDER=claude

# ── Idée #76 — Auto-réécriture des règles (évolution des axiomes) ─────────────
#
# Mango analyse ses corrections récurrentes et PROPOSE des évolutions de ses
# axiomes (à valider à la main). Provider de l'analyse (défaut : claude $0) :
# PROMPT_EVOLUTION_PROVIDER=claude
# Le créneau nocturne optionnel se règle dans le panneau (off par défaut).
